# =============================================================================
# Stripe Connect sample — environment placeholders
# Copy this file to `.env.local` and fill in real values from the Stripe Dashboard.
# =============================================================================

# PLACEHOLDER: Stripe secret API key (sk_test_... or sk_live_...)
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# PLACEHOLDER: Webhook signing secret for snapshot (billing) events
# From Dashboard Webhooks or: stripe listen --forward-to http://localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# PLACEHOLDER: Webhook signing secret for V2 thin events (Connect account requirements)
# From Dashboard Webhooks (Thin payload) or:
# stripe listen --thin-events 'v2.core.account[requirements].updated,...' --forward-thin-to http://localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET_THIN=whsec_REPLACE_ME_THIN

# PLACEHOLDER: Webhook signing secret for the /api/webhooks/thin endpoint
# From Dashboard Webhooks or: stripe listen --thin-events '...' --forward-thin-to http://localhost:3000/api/webhooks/thin
STRIPE_THIN_WEBHOOK_SECRET=whsec_REPLACE_ME_THIN

# PLACEHOLDER: Webhook signing secret for the /api/webhooks/billing endpoint
# From Dashboard Webhooks or: stripe listen --forward-to http://localhost:3000/api/webhooks/billing
STRIPE_BILLING_WEBHOOK_SECRET=whsec_REPLACE_ME_BILLING

# PLACEHOLDER: Platform Price ID used when a connected account subscribes to Blueprint
# Create a recurring Price in the Stripe Dashboard (Products → Add product → Recurring),
# then paste the price_... ID here.
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID=price_REPLACE_ME

# Public site URL used for Account Link return/refresh URLs and Checkout redirects.
# In local development this is usually http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
