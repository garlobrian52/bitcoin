# Stripe Connect sample — environment variables
# Copy this file to .env.local and fill in your values.

# PLACEHOLDER: Platform secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# PLACEHOLDER: Public app URL for redirects (onboarding, checkout success)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PLACEHOLDER: Webhook signing secret for snapshot events (subscriptions, billing)
# Get this from: stripe listen --forward-to http://localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# PLACEHOLDER: Webhook signing secret for thin events (V2 connected account updates)
# Get this from: stripe listen --thin-events 'v2.core.account[requirements].updated,...' --forward-thin-to http://localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET_THIN=whsec_REPLACE_ME

# PLACEHOLDER: Recurring Price ID for platform subscription charged to connected accounts
# Create a Product + recurring Price in the Stripe Dashboard, then paste the price_... ID here
STRIPE_PLATFORM_SUBSCRIPTION_PRICE_ID=price_REPLACE_ME
