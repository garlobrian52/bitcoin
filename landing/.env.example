# =============================================================================
# Stripe Connect sample — required environment variables
# Copy this file to `.env.local` and fill in values from https://dashboard.stripe.com/apikeys
# =============================================================================

# PLACEHOLDER: Replace with your Stripe secret key (sk_test_... or sk_live_...).
# Never commit real keys. The sample throws a clear error if this is missing.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Public site URL used to build Account Link / Checkout return URLs.
# Local default: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PLACEHOLDER: Platform subscription Price ID (price_...) created in your Stripe Dashboard.
# Used when a connected account subscribes to your platform plan via Checkout.
# Create a product + recurring price in Dashboard → Product catalog, then paste the price ID.
STRIPE_PRICE_ID=price_REPLACE_ME

# Webhook signing secret for THIN (V2 Accounts) events.
# From: stripe listen --thin-events '...' --forward-thin-to localhost:3000/api/webhooks/thin
# Or from a Dashboard event destination configured with Payload style = Thin.
STRIPE_THIN_WEBHOOK_SECRET=whsec_REPLACE_ME

# Webhook signing secret for SNAPSHOT (v1) subscription / billing events.
# From: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Or from a Dashboard webhook endpoint listening for customer.subscription.* etc.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
